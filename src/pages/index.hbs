<!DOCTYPE html>
<html lang="ja">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body>
<input class="inputText" type="text" id="urlInput" name="url" onClick="this.select()">
<button onclick="setDeckLoad()">実行</button>

<div id="outDocument">

</div>

<script>
function setDeckLoad(){
  const url = document.getElementById('urlInput').value;

  fetch('/scrape', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ url: url })
  })
    .then(response => response.json())
    .then(data => {
      const out = document.getElementById('outDocument');

      // 取得した HTML をそのまま表示
      out.innerHTML = data.body;
    })
    .catch(error => {
      console.error('Error:', error);
    });
}
</script>

</body>

</html>
